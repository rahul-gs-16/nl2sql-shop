# LLM Provider — choose one of: gemma, gemini, openai
MODEL_PROVIDER=gemma

# OpenAI — required when MODEL_PROVIDER=openai
OPENAI_API_KEY=

# Google Generative AI — required when MODEL_PROVIDER=gemini
GOOGLE_API_KEY=

# Ollama — required when MODEL_PROVIDER=gemma
# Use http://ollama:11434 inside Docker Compose; http://localhost:11434 for local bare-metal
OLLAMA_BASE_URL=http://ollama:11434

# SQLite database path inside the container
SQLITE_DB_PATH=/data/inventory.db
